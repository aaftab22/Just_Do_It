<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/white">

    <!-- Handle bar -->
    <View
        android:layout_width="48dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@android:color/darker_gray" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quick Capture"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- Hidden toggle group to keep binding working if needed, but set to GONE -->
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/captureTypeToggle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:visibility="gone"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:checkedButton="@id/btnTaskType">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTaskType"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Task" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNoteType"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Note" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- Name / Title input -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        app:hintEnabled="true">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/captureInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="What needs to be done?"
            android:inputType="textCapSentences"
            android:maxLines="3"
            android:imeOptions="actionDone" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Hidden Description input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/descriptionLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:hintEnabled="true">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/captureDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Add details..."
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="2"
            android:maxLines="5" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Priority toggle (tasks only) -->
    <LinearLayout
        android:id="@+id/priorityRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="High Priority"
            android:textSize="16sp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/capturePrioritySwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- Action buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Mic button for voice capture -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVoiceCapture"
            style="@style/Widget.MaterialComponents.Button.TextButton.Icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:icon="@android:drawable/ic_btn_speak_now"
            android:contentDescription="Voice capture" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Save button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveCapture"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Save"
            android:enabled="false" />
    </LinearLayout>

</LinearLayout>
